# Copy to .env and fill in real values. Never commit .env.

OPENAI_API_KEY=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

REDIS_URL=redis://localhost:6379

VAULT_CORPUS_PATH="/absolute/path/to/your/vault/subfolder"

# Self-signed JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=

# Login password for POST /login (which issues the JWT). Pick any value.
APP_PASSWORD=
